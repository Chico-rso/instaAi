PORT=3000
LOG_LEVEL=info
SCHEDULER_ENABLED=true
CRON_SCHEDULE=0 */4 * * *
TIMEZONE=Europe/Moscow
MANUAL_TRIGGER_TOKEN=
APP_BASE_PATH=/insta-ai
OUTBOUND_PROXY_URL=
MAX_REELS_PER_RUN=10
MAX_REELS_PER_MONTH=10

GLM_API_KEY=
GLM_API_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5
# Optional: overrides the built-in viral reels master prompt.
# You can use real line breaks (quoted value) or \n escapes.
VIRAL_REELS_MASTER_PROMPT=

TELEGRAM_MODE=polling
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=@your_channel
TELEGRAM_WEBHOOK_SECRET=
PROCESS_ON_WEBHOOK=false
TELEGRAM_DELIVERY_ENABLED=true
TELEGRAM_DELIVERY_CHAT_ID=
TELEGRAM_DELIVERY_DISABLE_NOTIFICATION=false

INSTAGRAM_ENABLED=true
INSTAGRAM_ACCESS_TOKEN=
IG_USER_ID=
INSTAGRAM_API_VERSION=v24.0
INSTAGRAM_SHARE_TO_FEED=true
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_AUTH_MODE=instagram-login
INSTAGRAM_GRAPH_BASE_URL=https://graph.facebook.com
INSTAGRAM_PROFILE_BASE_URL=https://graph.instagram.com
INSTAGRAM_AUTH_BASE_URL=https://www.instagram.com/oauth/authorize
INSTAGRAM_TOKEN_BASE_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_REDIRECT_URI=https://amiranbestaev.ru/insta-ai/auth/instagram/callback
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_content_publish
INSTAGRAM_FORCE_REAUTH=true

VIDEO_PROVIDER=template

PIKA_API_KEY=
PIKA_BASE_URL=https://queue.fal.run
PIKA_MODEL=fal-ai/pika/v2.2/text-to-video
PIKA_ASPECT_RATIO=9:16
PIKA_DURATION_SEC=10
PIKA_NEGATIVE_PROMPT=
PIKA_POLL_INTERVAL_MS=5000
PIKA_POLL_TIMEOUT_MS=480000

STORAGE_DRIVER=local
ARTIFACT_DIR=./data/artifacts
STATE_DIR=./data/state
PUBLIC_BASE_URL=https://amiranbestaev.ru/insta-ai

S3_REGION=us-east-1
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_BASE_URL=

REEL_TEMPLATE_FILE=./templates/reel-default-template.json
REEL_FONT_FILE=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
REEL_FPS=30
REEL_WIDTH=1080
REEL_HEIGHT=1920
REEL_AUDIO_FILE=
REEL_AUDIO_VOLUME=0.25
